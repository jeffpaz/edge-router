# /etc/edge-router/env — environment file for edge-router.service
#
# Copy this file to /etc/edge-router/env and fill in the values.
# Permissions should be 600 (owner-readable only):
#   sudo chmod 600 /etc/edge-router/env
#
# Lines beginning with # are comments and are ignored by systemd.
# Do NOT use 'export' or shell quoting — systemd reads this as plain KEY=VALUE.

# ── Local model (Ollama) ──────────────────────────────────────────────────────
# Override here to use a different model; default is set in the unit file.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# ── Routing ───────────────────────────────────────────────────────────────────
# Minimum confidence [0.0–1.0] to accept a local response without escalating.
# CONFIDENCE_THRESHOLD=0.70

# ── Cloud API keys ────────────────────────────────────────────────────────────
# Only the provider(s) you intend to use need a key.
# Skill → provider mapping: coding→claude, math_data→gemini,
#   current_events→grok, general→openai.

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# ── Cloud model overrides (optional) ─────────────────────────────────────────
# Uncomment to pin specific model versions.
# CLAUDE_MODEL=claude-sonnet-4-20250514
# GEMINI_MODEL=gemini-1.5-pro
# GROK_MODEL=grok-2-latest
# OPENAI_MODEL=gpt-4o
