# .env.example — copy to .env and fill in your values
#
# Usage:
#   cp .env.example .env
#   nano .env
#   ./deploy.sh
#
# Do NOT commit .env to version control — it contains secrets.
# This file (.env.example) is safe to commit.

# ── Ollama (local model) ──────────────────────────────────────────────────────
# Default connects via host.docker.internal (the host's Docker bridge gateway).
# This works out of the box on any Docker-on-Linux setup including Jetson.
#
# Alternative — once deploy.sh has run and connected the ollama container to
# the shared edge-net network, you can switch to the container hostname:
#   OLLAMA_BASE_URL=http://ollama:11434
#
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

# ── Routing ───────────────────────────────────────────────────────────────────
# Minimum confidence score [0.0–1.0] to use the local model's answer.
# Below this, the query is classified and sent to the matching cloud LLM.
CONFIDENCE_THRESHOLD=0.70

# ── Cloud API keys ────────────────────────────────────────────────────────────
# Note on naming: the .env uses friendly provider names (GEMINI, GROK).
# docker-compose.yml maps these to the SDK variable names the app reads
# (GOOGLE_API_KEY, XAI_API_KEY) — you don't need to set those separately.
#
# Only keys for providers you actually use are required:
#   coding queries      → Claude  (ANTHROPIC_API_KEY)
#   math / data queries → Gemini  (GEMINI_API_KEY)
#   current events      → Grok    (GROK_API_KEY)
#   general fallback    → OpenAI  (OPENAI_API_KEY)

ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=

# ── Cloud model overrides (optional) ─────────────────────────────────────────
# Uncomment to pin a specific model version. Defaults are set in config.py.
# CLAUDE_MODEL=claude-sonnet-4-20250514
# GEMINI_MODEL=gemini-1.5-pro
# GROK_MODEL=grok-2-latest
# OPENAI_MODEL=gpt-4o
